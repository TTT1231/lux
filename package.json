{
   "name": "trw-cli",
   "version": "1.0.0",
   "description": "One-click project formatting & VSCode config CLI",
   "type": "module",
   "bin": {
      "trw1": "./dist/index.js"
   },
   "files": [
      "dist"
   ],
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "prepublishOnly": "bun run build",
      "lint": "eslint .",
      "lint:fix": "eslint \"src/**/*.{js,ts}\" --fix",
      "format": "prettier --write \"src/**/*.{ts,js,json}\"",
      "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
      "cspell": "cspell --gitignore \"src/**/*\"",
      "type:check": "tsc --noEmit",
      "code:check": "bun run lint && bun run format:check",
      "code:fix": "bun run lint:fix && bun run format",
      "code:check:all": "bun run lint && bun run format:check && bun run cspell",
      "code:fix:all": "bun run lint:fix && bun run format",
      "pretest": "bun run build",
      "test": "vitest run",
      "test:watch": "vitest",
      "bump:deps": "bunx tsx scripts/bump-deps.ts"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "dependencies": {
      "chalk": "5",
      "commander": "^14.0.3"
   },
   "devDependencies": {
      "@eslint/js": "10.0.1",
      "@types/node": "^25.5.2",
      "cspell": "10.0.0",
      "eslint": "10.2.0",
      "eslint-config-prettier": "10.1.8",
      "eslint-plugin-prettier": "5.5.5",
      "prettier": "3.8.1",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "typescript-eslint": "8.58.0",
      "vitest": "^4.1.3"
   }
}
